<!DOCTYPE html>
<html>
<head>
<title>Cyber Quiz</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<h1>Cyber Security Quiz</h1>

<form id="quizForm">

<div class="question">
<p>1. What is phishing?</p>
<input type="radio" name="q1" value="a"> Fake website<br>
<input type="radio" name="q1" value="b"> Antivirus<br>
</div>

<div class="question">
<p>2. Strong password should contain?</p>
<input type="radio" name="q2" value="a"> Only letters<br>
<input type="radio" name="q2" value="b"> Letters, numbers, symbols<br>
</div>

<div class="question">
<p>3. Malware is?</p>
<input type="radio" name="q3" value="a"> Safe software<br>
<input type="radio" name="q3" value="b"> Harmful software<br>
</div>

<div class="question">
<p>4. HTTPS means?</p>
<input type="radio" name="q4" value="a"> Secure connection<br>
<input type="radio" name="q4" value="b"> Virus<br>
</div>

<button type="button" onclick="submitQuiz()">Submit</button>

</form>

<h2 id="result"></h2>

<script>
function submitQuiz() {
let score = 0;

if(document.querySelector('input[name="q1"]:checked')?.value=="a") score++;
if(document.querySelector('input[name="q2"]:checked')?.value=="b") score++;
if(document.querySelector('input[name="q3"]:checked')?.value=="b") score++;
if(document.querySelector('input[name="q4"]:checked')?.value=="a") score++;

document.getElementById("result").innerHTML = "Your Score: " + score + "/4";
}
</script>

</body>
